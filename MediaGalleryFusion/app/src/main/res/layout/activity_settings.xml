<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Spinner android:id="@+id/themeSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" />
        <Spinner android:id="@+id/accentSpinner" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/portrait_columns" android:layout_marginTop="18dp" />
        <TextView android:id="@+id/portraitValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" />
        <com.google.android.material.slider.Slider android:id="@+id/portraitSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="2" android:valueTo="6" android:stepSize="1" android:value="3" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/landscape_columns" android:layout_marginTop="12dp" />
        <TextView android:id="@+id/landscapeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" />
        <com.google.android.material.slider.Slider android:id="@+id/landscapeSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="3" android:valueTo="8" android:stepSize="1" android:value="5" />

        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/autoPlaySwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/auto_play_media" android:layout_marginTop="16dp" />
        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/fileNamesSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/show_file_names" android:layout_marginTop="12dp" />
        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/animationsSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/enable_animations" android:layout_marginTop="12dp" />
        <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/confirmDeleteSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/confirm_deletion" android:layout_marginTop="12dp" />

        <Button android:id="@+id/saveButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="@string/save" />
    </LinearLayout>
</ScrollView>
